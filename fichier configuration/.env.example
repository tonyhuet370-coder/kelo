# Configuration Kélonia pour Synology NAS
# =======================================
# Les deux conteneurs (web + simulateur) tournent sur le même NAS

# Port du site web
# Défaut: 8080 (les ports < 1024 nécessitent des droits root)
# Synology ports réservés: 80, 443, 3000, 5000, 8000, 8080, 8443
# Si 8080 est occupé, essayer: 8888, 9090, 10000
WEB_PORT=8080

# MQTT broker cible (interne Docker: mosquitto, externe: IP/hostname)
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# Port du simulateur (interne, n'a pas besoin d'être accessible depuis l'extérieur)
# Les deux conteneurs communiquent via le réseau Docker
SIMULATEUR_PORT=5000

# InfluxDB
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin12345
INFLUXDB_ORG=kelonia
INFLUXDB_BUCKET=kelonia
INFLUXDB_TOKEN=kelonia-super-token

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin


