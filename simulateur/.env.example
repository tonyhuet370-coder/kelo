

# Environnement
FLASK_ENV=production

# Port d'écoute du simulateur
SIMULATEUR_PORT=5000

# Adresse d'écoute (0.0.0.0 pour accepter toutes les connexions)
SIMULATEUR_HOST=0.0.0.0

# Broker MQTT cible
# Pour publier vers le serveur de supervision dedie:
# MQTT_BROKER=192.168.62.2
MQTT_BROKER=host.docker.internal
MQTT_PORT=1883

# Configuration Telegram
TELEGRAM_ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_COOLDOWN_SECONDS=60

# Seuils d'alerte
TEMPERATURE_ALERT_THRESHOLD=32
HUMIDITE_ALERT_THRESHOLD=95
VIBRATION_ALERT_THRESHOLD=5
TENSION_ALERT_THRESHOLD=1

# Topic de publication
MQTT_TOPIC_TEMPLATE=kelo/nid/{nid}/telemetry

# Nid simule et cadence d'envoi
SIMULATED_NID=A12
PUBLISH_INTERVAL=5
