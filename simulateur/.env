

# Environnement
FLASK_ENV=production

# Port d'écoute du simulateur
SIMULATEUR_PORT=5000

# Adresse d'écoute (0.0.0.0 pour accepter toutes les connexions)
SIMULATEUR_HOST=0.0.0.0

# Broker MQTT cible
# Pour publier vers le serveur de supervision dedie:

MQTT_BROKER=172.19.216.4
MQTT_PORT=1883


MQTT_TOPIC_TEMPLATE=kelo/nid/{nid}/telemetry


SIMULATED_NID=A12
PUBLISH_INTERVAL=5
