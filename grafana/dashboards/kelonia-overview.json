{
  "id": null,
  "uid": "kelonia-overview",
  "title": "kelonia",
  "tags": ["kelonia", "mqtt", "telemetry"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Temperature (degC)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-kelonia" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "unit": "celsius"
        },
        "overrides": []
      },
      "targets": [
        {
          "query": "from(bucket: \"kelonia\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\" and r._field == \"temperature\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Humidite (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
